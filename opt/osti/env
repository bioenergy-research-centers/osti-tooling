# OSTI Sync Environment Configuration
# This file is sourced by osti_hourly_sync.sh to customize behavior per host.
# All variables are optional; defaults in the script will be used if not set here.

# Shared directories
# REPO_DIR="/opt/osti/brc-schema"
# STATE_DIR="/opt/osti/state"
# OUT_DIR="/opt/osti/state/runs"
# LOG_DIR="/opt/osti/logs"
# LOCK_FILE="/opt/osti/state/osti_hourly_sync.lock"

# E-Link API configuration
# ELINK_BEARER_TOKEN="your-bearer-token-here"  # Required: Bearer token for OSTI E-Link API
# ELINK_API_URL="https://www.osti.gov/elink2api/records"
# SITE_OWNERSHIP_CODE="CBI"
# ELINK_PAGE_SIZE="500"

# Configuration file fallback (if token not set above)
# CONFIG_INI="/var/www/OSTI_config.ini"

# Web publishing destinations
# WEB_OSTI_JSON="/var/www/html/CBI/cbi_osti.json"
# WEB_BRC_JSON="/var/www/html/CBI/cbi.json"
# WEB_PUBLICATIONS_JSON="/var/www/html/CBI/cbi_publications.json"

# Retention policy (keep 168 runs = 7 days hourly)
# KEEP_RUNS="168"
